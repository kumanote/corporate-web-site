---
const companyData = [
  { label: "会社名", value: "合同会社kumanote" },
  { label: "所在地", value: "〒104-0061 東京都中央区銀座一丁目22番11号 銀座大竹ビジデンス 2F" },
  { label: "設立", value: "2016年11月18日" },
  { label: "資本金", value: "2,000,000円" },
  { label: "事業内容", value: "システムの受託開発、インターネットサービスの企画及び運営" },
  { label: "従業員数", value: "2名" },
];
---

<section id="about" class="py-16 sm:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-base font-semibold tracking-wider text-primary-600 uppercase">
        会社概要
      </h2>
      <p class="mt-2 text-3xl font-extrabold text-gray-900 dark:text-gray-50 tracking-tight sm:text-4xl">
        会社情報
      </p>
    </div>
    <div class="overflow-hidden">
      <div class="mt-8">
        <dl>
          {companyData.map((item, index) => (
            <div
              class:list={[
                "px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6",
                index % 2 === 0 ? "bg-gray-100 dark:bg-gray-800" : "bg-transparent",
              ]}
            >
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">
                {item.label}
              </dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-gray-50 sm:mt-0 sm:col-span-2">
                {item.value}
              </dd>
            </div>
          ))}
          <div class="px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6 bg-gray-100 dark:bg-gray-800">
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">
              顧問税理士
            </dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-gray-50 sm:mt-0 sm:col-span-2">
              <a
                href="https://aiknot.jp/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary-600 hover:text-primary-500 dark:text-primary-400 dark:hover:text-primary-300"
              >
                AIknot 日本橋会計事務所
              </a>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
